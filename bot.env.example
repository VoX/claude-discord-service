# ~/.bot.env — user-local overrides for the claude-discord systemd unit.
# Copy this to ~/.bot.env (or point EnvironmentFile= at another path)
# and customize the values. Lines starting with '#' are comments.
#
# Systemd reads this file as plain KEY=VALUE pairs. No shell expansion,
# no quoting tricks — write literal paths.

# --- REQUIRED -----------------------------------------------------------

# The claude --resume session name. This is what `claude -n <name>` was
# called with when you first started your bot. Must already exist.
BOT_SESSION_NAME=changeme

# --- OPTIONAL -----------------------------------------------------------

# Screen session name the service wraps `claude` inside. Only matters if
# you run multiple bots on one machine (each needs a unique name).
# SCREEN_SESSION=claude-discord

# Extra directory mounted into the claude session via --add-dir. Useful
# for a "personality" repo or notes dir you want the bot to see.
# BOT_ADD_DIR=/home/you/claude-personality

# Space-separated plugin specs for --dangerously-load-development-channels.
# Omit if you only use marketplace-installed plugins.
# BOT_PLUGINS=plugin:discord@vox-plugins plugin:scheduler@vox-plugins

# --- MODEL SELECTION (optional) ----------------------------------------

# Override the default model / subagent model / effort level. Values shown
# are what the maintainer runs; omit to use Claude Code's defaults.
# ANTHROPIC_MODEL=claude-opus-4-7
# CLAUDE_CODE_SUBAGENT_MODEL=claude-opus-4-7
# CLAUDE_CODE_EFFORT_LEVEL=max
# CLAUDE_CODE_AUTO_COMPACT_WINDOW=750000
