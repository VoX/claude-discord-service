[Unit]
Description=Claude Code Discord bot (%i)
After=network.target
# Cap the retry storm: if 3 starts inside 60s all fail, give up and mark the
# unit failed. StartLimitAction=none means "don't try harder via reboot" — we
# expect a human (or a companion heal timer, see follow-up) to notice the
# failed state and intervene. Prevents the wrapper-guard-tripping-forever
# pathology where bad config or a stuck stray claude burns CPU indefinitely.
# These keys MUST live in [Unit] per systemd docs — [Service] silently ignores
# them.
StartLimitBurst=3
StartLimitInterval=60
StartLimitAction=none

[Service]
Type=forking
# ExecStartPre strips orphaned `thinking`/`redacted_thinking` blocks from the
# active session transcript before claude --resume replays it — workaround for
# anthropics/claude-code#63147 which would otherwise 400-loop the resume after
# any mid-turn interruption. Leading `-` so a sanitizer failure (e.g. permission
# error) doesn't block service start; the script swallows its own non-fatal
# exits internally too.
ExecStartPre=-%h/projects/claude-discord-service/bin/sanitize-pre.sh
ExecStart=/usr/bin/screen -dmS ${SCREEN_SESSION} %h/projects/claude-discord-service/bin/claude-discord-wrapper.sh
WorkingDirectory=%h/claude-discord/%i
Restart=always
# 15s back-off is slow enough that a persistent fault doesn't hammer the box,
# fast enough that a transient hiccup recovers without operator intervention.
# Combined with [Unit] StartLimitBurst=3 / StartLimitInterval=60 above, this
# gives roughly 3 retries spread over ~45s before the unit goes failed.
RestartSec=15
# control-group: SIGTERM every pid in the cgroup (claude + bun MCP children),
# not just the main screen pid. Ensures MCP servers shut down cleanly on stop
# instead of getting reparented to pid 1 when the main exits first.
KillMode=control-group
KillSignal=SIGTERM
# Enough time for claude + plugin MCP servers to drain websockets and exit
# before systemd escalates to SIGKILL.
TimeoutStopSec=30
SuccessExitStatus=1
MemoryMax=8G
MemoryHigh=6G

# Per-instance overrides. install.sh <name> seeds this from bot.env.example.
# Leading '-' = service still starts if the file is missing (wrapper will
# fail fast on absent BOT_SESSION_NAME).
EnvironmentFile=-%h/claude-discord/%i/.bot.env

# Per-instance defaults derived from %i. Override any of these in
# the per-instance .bot.env if you need to.
Environment=BOT_SESSION_NAME=%i
Environment=SCREEN_SESSION=claude-discord-%i
Environment=CLAUDE_CONFIG_DIR=%h/claude-discord/%i/.claude

# Shared runtime defaults — same for every instance.
Environment=PATH=%h/.bun/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
Environment=CLAUDE_ENABLE_STREAM_WATCHDOG=1
Environment=CLAUDE_STREAM_IDLE_TIMEOUT_MS=90000
Environment=CLAUDE_CODE_RESUME_INTERRUPTED_TURN=1
Environment=CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1
Environment=CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1
Environment=DISABLE_COST_WARNINGS=1
Environment=CLAUDE_CODE_NO_FLICKER=1
# Disable TUI mouse capture. Fullscreen rendering (NO_FLICKER) otherwise enables SGR
# mouse reporting, whose sequences leak into the `screen` pane as literal coordinate
# text (e.g. "29;33M") when a mouse moves over an attached terminal. Headless bots
# don't need mouse. Diagnosed on catboy 2026-06-21; see code.claude.com/docs/en/fullscreen.md.
Environment=CLAUDE_CODE_DISABLE_MOUSE=1
Environment=VOX_PLUGINS_ENABLED=1
# Skip Discord permission prompts; the bot's persona rules (CLAUDE.md) do
# the gating instead. Requires discord plugin >= 0.1.18. Comment out if
# you want the Allow/Deny DM flow on tool calls.
Environment=DISCORD_AUTO_ALLOW_PERMISSIONS=1

StandardOutput=append:%h/claude-discord/%i/logs/claude-discord.log
StandardError=append:%h/claude-discord/%i/logs/claude-discord.error.log

[Install]
WantedBy=default.target
